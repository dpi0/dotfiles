font_family      JetBrainsMono Nerd Font
bold_font        auto
italic_font      auto
bold_italic_font auto
font_size	11.0
# background_opacity 0.9
background_opacity 0.9
dynamic_background_opacity yes
# background #000000

copy_on_select yes

# map ctrl+shift+c copy_to_clipboard
map ctrl+v paste_from_clipboard
confirm_os_window_close 0
map alt+shift+u new_tab
map alt+shift+h previous_tab
map alt+shift+l next_tab
map alt+shift+w close_window
map alt+shift+ctrl+l move_tab_forward
map alt+shift+ctrl+h move_tab_backward
map alt+shift+r set_tab_title
map alt+shift+1 goto_tab 1
map alt+shift+2 goto_tab 2
map alt+shift+3 goto_tab 3
map alt+shift+4 goto_tab 4
map alt+shift+0 goto_tab 5


# BEGIN_KITTY_THEME
# Pro
include current-theme.conf
# END_KITTY_THEME