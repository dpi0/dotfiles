source $DOTFILES/zsh/.zsh_functions

# --- Terminal Aliases ---
alias apt="sudo apt"
alias n="sudo nala"
alias t="tmux"
alias ta="t a -t"
alias tls="t ls"
alias tn="t new-session -s"
alias tk="t kill-session -t"
alias tr="t rename-session -t"

# --- File Management Aliases ---
alias lx="eza --icons -a"
alias l="lx -l"
alias ls="lx -l"
alias lt="lx -T"

# --- System Aliases ---
alias s="sudo"
alias c="bat"
alias cat="bat"
alias xx="exit"
alias ping="gping"
alias tree="eza --tree --long"
alias gg="googler"
alias re="exec zsh"
alias jj="j -"
alias history="history | lolcat"
alias ps="ps | lolcat"
alias date="date | lolcat"

# --- Python and Poetry Aliases ---
alias py="python3"
alias ppf="pip freeze | lolcat"
alias install="poetry add"
alias remove="poetry remove"
alias update="poetry update"
alias init="poetry init"
alias new="poetry new"
alias list="poetry show -tlav"
alias shl="poetry shell"
alias search="poetry search"
alias lock="poetry lock"
alias ver="poetry version"
alias about="poetry about"
alias ppr="pip freeze > requirements.txt"

# --- Service Management Aliases ---
alias statusServ="sudo systemctl status"
alias listServ="sudo systemctl list-unit-files"
alias startServ="sudo systemctl start"
alias stopServ="sudo systemctl stop"
alias blockServ="sudo systemctl mask"
alias unblockServ="sudo systemctl unmask"
alias restartServ="sudo systemctl reload-or-restart"
alias enableServ="sudo systemctl enable"
alias disableServ="sudo systsemctl disable"

# --- File Operations Aliases ---
alias rem="rm -rfi"
alias del="trash-put"
alias dlist="trash-list"
alias drm="trash-rm"
alias dclearrem="trash-empty"
alias drest="trash-restore"

# --- Archive Extraction Alias ---
alias ex="extract"

# --- File Explorer Aliases ---
alias opene="explorer.exe ."
alias open="nautilus ."

# --- Editor Aliases ---
#alias vim=nvim
alias vi=vim
alias v=vim

# --- Config Management Alias ---
alias cz=chezmoi

# --- Custom Directories Aliases ---
alias winback="cd /mnt/c/Users/divyansh/Documents/Backup\ Settings\ \&\ Files"
alias cdw="cd /mnt/shared/dwnloads"
alias cdww="cd /mnt/s/dwnloads"
alias cdd="cd /mnt/shared/dev"
